---
// src/pages/app/index.astro
// Dashboard principal — página protegida.
// Etapa 0: solo verifica autenticación y muestra datos básicos del usuario.
// La lógica de cotizaciones se implementará en etapas posteriores.
import Base from '../../layouts/Base.astro';
---

<Base title="A Cotizar! — Dashboard">
  <main style="max-width:600px; margin:2rem auto;">
    <div style="display:flex; justify-content:space-between; align-items:center;">
      <h1 style="margin:0;">A Cotizar!</h1>
      <button class="btn-danger" onclick="handleLogout()">Cerrar sesión</button>
    </div>

    <div id="loading" style="margin-top:2rem; color:#888;">Cargando…</div>

    <div id="user-info" style="display:none; margin-top:2rem; background:#fff; padding:1.5rem; border-radius:8px; border:1px solid #e5e7eb;">
      <img id="user-avatar" src="" alt="Avatar" width="48" height="48"
           style="border-radius:50%; display:block; margin-bottom:1rem;"
           onerror="this.style.display='none'" />
      <p><strong>Nombre:</strong> <span id="user-name"></span></p>
      <p><strong>Email:</strong>  <span id="user-email"></span></p>
      <p style="margin:0; color:#6b7280; font-size:0.875rem;">
        ✅ Autenticación funcionando. Dashboard completo en próximas etapas.
      </p>
    </div>
  </main>

  <script is:inline>
    (async () => {
      await Auth.init(AUTH_CONFIG);

      // requireAuth() redirige a Auth0 si no hay sesión activa
      const user = await Auth.requireAuth();
      if (!user) return;

      // Mostrar datos del usuario
      document.getElementById('loading').style.display = 'none';

      const info = document.getElementById('user-info');
      info.style.display = 'block';

      document.getElementById('user-name').textContent  = user.name  ?? '—';
      document.getElementById('user-email').textContent = user.email ?? '—';

      const avatar = document.getElementById('user-avatar');
      if (user.picture) {
        avatar.src = user.picture;
      } else {
        avatar.style.display = 'none';
      }
    })();

    function handleLogout() {
      Auth.logout();
    }
  </script>
</Base>

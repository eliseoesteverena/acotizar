---
// src/pages/app/index.astro
// Dashboard principal — página protegida.
// Etapa 0: solo verifica autenticación y muestra datos básicos del usuario.
// La lógica de cotizaciones se implementará en etapas posteriores.
import Base from '../../layouts/Base.astro';
---

<Base title="A Cotizar! — Dashboard">
 <div id="app-shell" style="display:none">
  <!-- TODO: dashboard content en etapas siguientes -->
  <h1>Dashboard</h1>
</div>

<script src="https://cdn.auth0.com/js/auth0-spa-js/2.0/auth0-spa-js.production.js"></script>
<script>
  /**
   * Guarda de autenticación y onboarding.
   * Se ejecuta antes de mostrar cualquier contenido del dashboard.
   *
   * Flujo:
   *   1. ¿Está autenticado?     → No  → /
   *   2. POST /api/profile      → needsOnboarding? → /app/config
   *   3. Todo OK                → mostrar dashboard
   */
  (async function guard() {
    const AUTH0_DOMAIN = window.__AUTH0_DOMAIN__ || '';
    const AUTH0_CLIENT = window.__AUTH0_CLIENT_ID__ || '';
    const AUTH0_AUDIENCE = window.__AUTH0_AUDIENCE__ || '';
    
    if (!window.auth0 || !AUTH0_DOMAIN || !AUTH0_CLIENT) return;
    
    const client = await window.auth0.createAuth0Client({
      domain: AUTH0_DOMAIN,
      clientId: AUTH0_CLIENT,
      authorizationParams: { audience: AUTH0_AUDIENCE },
    });
    
    // 1. ¿Autenticado?
    if (!await client.isAuthenticated()) {
      window.location.replace('/');
      return;
    }
    
    // 2. Verificar onboarding (idempotente — si ya existe el perfil, lo devuelve sin cambios)
    try {
      const token = await client.getTokenSilently({ audience: AUTH0_AUDIENCE });
      const res = await fetch('/api/profile', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
      });
      
      if (res.ok) {
        const data = await res.json();
        if (data.needsOnboarding) {
          window.location.replace('/app/config');
          return;
        }
      }
    } catch (err) {
      // Si falla la verificación, dejamos pasar (no bloqueamos el dashboard por un error de red)
      console.warn('Guarda de onboarding falló silenciosamente:', err);
    }
    
    // 3. Mostrar dashboard
    document.getElementById('app-shell').style.display = 'block';
  })();
</script>
</body>

</html>
</Base>
